generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  password      String
  nombre        String
  role          String         @default("USER")
  createdAt     DateTime       @default(now())
  refreshTokens RefreshToken[]
}

model Customer {
  id               String   @id @default(uuid())
  nombre           String
  email            String   @unique
  telefono         String?
  direccion        String
  direccionIv      String? 
  direccionAuthTag String? 
  documentoFiscal  String
  documentoIv      String? 
  documentoAuthTag String? 
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  orders           Order[]
}


model Order {
  id            String   @id @default(uuid())
  clienteId     String
  folio         String   @unique
  monto         Decimal  @db.Decimal(18, 2)
  moneda        String
  estatus       String   @default("CREADA")
  notasInternas String?
  notasIv       String   @db.VarChar(255) @default("")
  notasAuthTag  String   @db.VarChar(255) @default("")
  createdAt     DateTime @default(now())

  customer Customer @relation(fields: [clienteId], references: [id])
  @@index([clienteId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  user      User @relation(fields: [userId], references: [id])
}
